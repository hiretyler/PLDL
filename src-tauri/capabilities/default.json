{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the PLDL main window: core defaults plus permission to spawn the bundled pldl-server sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/pldl-server",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/pldl-server",
          "sidecar": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write"
  ]
}
